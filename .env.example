# privacy-indexer — runtime configuration (docker compose reads this as env_file).
# Copy to `.env` and edit. All values map to CLI flags via clap `env = …`.

# ── Required ──────────────────────────────────────────────────────────────────
# Ethereum JSON-RPC (HTTP/HTTPS). The WS URL is derived (https→wss) unless set.
PRIVACYBTC_ETH_RPC_URL=https://your-rpc.example.com
# Explicit WebSocket URL (only if the provider's WS path differs from HTTP).
#PRIVACYBTC_ETH_WS_URL=wss://your-rpc.example.com/ws

# Chain id of the network above.
PRIVACYBTC_CHAIN_ID=1

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated browser origins allowed to call the indexer (your web app).
PRIVACYBTC_CORS_ORIGINS=https://app.example.com

# ── Admin write API ───────────────────────────────────────────────────────────
# Required for POST /frozen. When unset, admin write endpoints are disabled.
# Send as: Authorization: Bearer <token>
#PRIVACYBTC_INDEXER_ADMIN_TOKEN=change-me-long-random-token

# ── Pool discovery (recommended primary mechanism) ───────────────────────────
# Auto-discover pools by scanning `Perc20Created` chain-wide and registering each
# match automatically. With this ON the frontend never needs to register pools —
# the indexer self-heals (picks up assets created while it was down, too).
PRIVACYBTC_INDEXER_DISCOVER_POOLS=1
# Optional: restrict discovery to specific issuer addresses (comma-separated).
# Empty ⇒ discover every pERC20 on the chain.
#PRIVACYBTC_INDEXER_DISCOVER_ISSUER=0xIssuerA,0xIssuerB
# Poll interval (seconds) for the discovery scan.
#PRIVACYBTC_INDEXER_DISCOVER_POLL_SECS=12

# ── Optional ──────────────────────────────────────────────────────────────────
# First block to scan when no checkpoint exists (deploy block of the factory).
# Discovery and per-pool scanning both start here, so set it to the factory's
# deploy block to avoid rescanning the whole chain.
PRIVACYBTC_START_BLOCK=0

# Manual registration (POST /pools) remains as a fallback (e.g. pools created
# before START_BLOCK). It needs no token: the indexer verifies on-chain that the
# address is a genuine pERC20 (it emitted `Perc20Created`). Verified addresses
# are cached, so the browser can register pools directly without any secret.

# Signer key (hex secp256k1) for relaying Phase 2 confirmations on-chain.
# Not needed for a pure issuance/aggregation indexer.
#PRIVACYBTC_INDEXER_SIGNER_KEY=

# PostgreSQL state backend. docker-compose.yml wires this to the bundled
# postgres service automatically — override only for an external database.
# When unset (bare-metal runs), state falls back to the JSON file backend.
#PRIVACYBTC_INDEXER_DATABASE_URL=postgres://user:pass@db:5432/privacybtc

# Password for the bundled postgres service in docker-compose.yml.
POSTGRES_PASSWORD=change-me

# Host bind/port for docker-compose. Default bind is loopback-only: put a
# reverse proxy in front, expose read endpoints publicly, and keep write/admin
# endpoints authenticated or internal.
INDEXER_HOST_BIND=127.0.0.1
INDEXER_HOST_PORT=8787

# Note: PRIVACYBTC_INDEXER_BIND / _DATABASE_URL / _POOLS_REGISTRY are set by
# docker-compose.yml (container listens on 0.0.0.0:8787, bundled postgres,
# /data on a named volume).
